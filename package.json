{
  "name": "seazone-maquina-criativos",
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "audit": "node src/audit.js",
    "copy": "node src/generate-copy.js",
    "copy:dry": "node src/generate-copy.js --dry-run",
    "prompts": "node src/generate-prompts.js",
    "preview": "node src/generate-preview.js",
    "all": "node src/audit.js && node src/generate-copy.js --dry-run && node src/generate-prompts.js && node src/generate-preview.js",
    "all:live": "node src/audit.js && node src/generate-copy.js && node src/generate-prompts.js && node src/generate-preview.js",
    "ver": "npx -y serve output -p 3000 --no-clipboard",
    "testar": "node teste.js --dry-run",
    "rodar": "node teste.js",
    "overlay": "node src/overlay.js",
    "video:narrado": "node src/video-narrado.js",
    "video:narrado:reels": "node src/video-narrado.js --reels",
    "video:narrado:dry": "node src/video-narrado.js --dry-run",
    "video:apresentadora": "node src/video-apresentadora.js",
    "video:apresentadora:reels": "node src/video-apresentadora.js --reels",
    "video:apresentadora:dry": "node src/video-apresentadora.js --dry-run",
    "narrar": "node src/narrar.js",
    "narrar:vn": "node src/narrar.js --vn",
    "narrar:va": "node src/narrar.js --va",
    "narrar:dry": "node src/narrar.js --dry-run",
    "narrar:sem-trilha": "node src/narrar.js --sem-trilha",
    "narrar:video": "node src/narrar-video.js",
    "narrar:video:reels": "node src/narrar-video.js --reels",
    "narrar:video:dry": "node src/narrar-video.js --dry-run",
    "narrar:video:sem-trilha": "node src/narrar-video.js --sem-trilha",
    "build": "node build.js",
    "server": "node server.js"
  },
  "dependencies": {
    "@fal-ai/client": "^1.3.0",
    "chalk": "^5.3.0",
    "dotenv": "^16.0.0",
    "express": "^5.2.1",
    "fs-extra": "^11.0.0",
    "node-fetch": "^3.3.0",
    "sharp": "^0.34.5"
  }
}
