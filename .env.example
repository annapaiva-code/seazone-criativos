# Google AI Studio — Gemini 2.5 Flash (copies e roteiros)
# aistudio.google.com → Get API key
GOOGLE_API_KEY=sua_chave_google_aqui

# ── Provedores de imagem (em ordem de prioridade) ──────────────────────────
# Basta configurar UM. O sistema tenta na ordem: Together → HuggingFace → Pollinations

# Together AI — FLUX.1-schnell-Free (100% grátis, sem cartão)
# api.together.xyz → Settings → API Keys
TOGETHER_API_KEY=sua_chave_together_aqui

# HuggingFace — FLUX.1-schnell (grátis com conta)
# huggingface.co → Settings → Access Tokens
HF_TOKEN=seu_token_hf_aqui

# Pollinations.ai — sempre funciona, sem chave (fallback automático)

# ── Opcional (se tiver créditos) ───────────────────────────────────────────
# fal.ai — modelos premium (Flux Pro, Kling, Minimax)
# FAL_KEY=sua_chave_fal_aqui
